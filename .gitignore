!**/requirements.txt
# v0.10.5.3 fix: hallucinations corpus files were silently dropped when
# *.txt was added globally. The corpus is loaded by hallucination-filter.ts
# at runtime — without these files the bot ships with empty filter,
# letting whisper hallucinations ("thanks for watching", "subscribe to my
# channel") leak into transcripts. See services/vexa-bot/core/src/services/
# hallucinations/ for the canonical location.
!services/vexa-bot/core/src/services/hallucinations/*.txt
!scripts/notary/lib/hallucinations/*.txt
manifest.csv

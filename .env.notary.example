# Секреты для надстройки meeting-notary поверх Vexa
# Скопируй этот файл в .env.notary рядом и заполни реальные значения.
# .env.notary в .gitignore — НЕ коммитить.
#
# Назначение каждой переменной см. в плане:
#   ~/Projects/me/plans/2026-05-26-bot-notarius-telemost.md

# Refresh-token Google OAuth для Calendar API (бот ilya.rybalka@anzhee.ru).
# Используется планировщиком встреч (Ф5) для опроса календаря.
GOOGLE_OAUTH_REFRESH_TOKEN=

# Bot API token Telegram-бота, через который шлются ошибки и подтверждения.
# Используется обёрткой tg-send (Ф5, Ф6) и адаптером Telemost для push о waiting room (Ф2).
TELEGRAM_BOT_TOKEN=

# chat_id Ильи в Telegram. Используется адаптером Telemost для push о waiting room.
# Узнать: написать боту /start, потом GET https://api.telegram.org/bot<TOKEN>/getUpdates
TELEGRAM_CHAT_ID=

# URL CPU transcription-service (faster-whisper medium) на VPS.
# Обычно резолвится через docker bridge gateway IP.
TRANSCRIPTION_SERVICE_URL=http://172.17.0.1:8083/v1/audio/transcriptions

# Опционально. Ключ Claude API для LLM-маппинга имён спикеров (Ф3).
# Если пусто — маппинг работает только regex+морфология, без LLM-добивки.
ANTHROPIC_API_KEY=
